{
  "rewrites": [
    {
      "source": "/apply",
      "destination": "https://app-tiance-io.vercel.app/apply"
    },
    {
      "source": "/apply/:path*",
      "destination": "https://app-tiance-io.vercel.app/apply/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://app-tiance-io.vercel.app/_next/:path*"
    },
    {
      "source": "/api/applications/:path*",
      "destination": "https://app-tiance-io.vercel.app/api/applications/:path*"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "https://app-tiance-io.vercel.app/api/auth/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://app-tiance-io.vercel.app/auth/:path*"
    }
  ]
}
